{
  "name": "gini-agent",
  "version": "0.3.0",
  "private": true,
  "license": "MIT",
  "description": "The agent that remembers and learns.",
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@tanstack/react-query": "^5.101.1",
      "@types/bun": "^1.3.0",
      "typescript": "~6.0.3"
    }
  },
  "scripts": {
    "gini": "bun run packages/runtime/src/cli.ts",
    "server": "bun run packages/runtime/src/server.ts",
    "smoke": "bun run packages/runtime/src/cli.ts smoke",
    "test": "bun test --parallel ./packages/runtime/src ./skills ./packages/mobile/src ./packages/mobile/plugins",
    "posttest": "bun --cwd=packages/web test --isolate",
    "typecheck": "bunx tsc --noEmit && bun run --filter './packages/*' typecheck",
    "web:dev": "bun --cwd packages/web run dev",
    "web:build": "bun --cwd packages/web run build",
    "web:start": "bun --cwd packages/web run start",
    "mobile": "bun --cwd packages/mobile run start",
    "mobile:ios": "bun --cwd packages/mobile run ios",
    "mobile:android": "bun --cwd packages/mobile run android"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  },
  "trustedDependencies": [
    "onnxruntime-node",
    "protobufjs",
    "sharp",
    "unrs-resolver"
  ],
  "patchedDependencies": {
    "playwright-core@1.61.1": "patches/playwright-core@1.61.1.patch"
  }
}
