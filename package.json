{
  "name": "gini-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "gini": "./src/cli.ts"
  },
  "scripts": {
    "gini": "bun run src/cli.ts",
    "server": "bun run src/server.ts",
    "smoke": "bun run src/cli.ts smoke",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit && cd web && bunx tsc --noEmit",
    "web:dev": "cd web && bun run dev",
    "web:build": "cd web && bun run build",
    "web:start": "cd web && bun run start"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "playwright-core": "^1.60.0"
  },
  "trustedDependencies": [
    "onnxruntime-node",
    "protobufjs"
  ]
}
