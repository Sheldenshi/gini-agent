# Mobile app env. Copy to `mobile/.env` and fill in. Never commit `.env`.
# These are consumed by `mobile/app.config.ts` at build / dev time.

# EAS project id (run `eas init` in the mobile/ directory to get one).
# The OTA updates URL is derived from this as `https://u.expo.dev/<id>`.
EAS_PROJECT_ID=

# Expo account / org that owns the EAS project (your `expo whoami`).
EXPO_OWNER=

# Apple Developer Team ID (10-char string from developer.apple.com).
# Required for the lock-screen approval notification service extension.
APPLE_TEAM_ID=
