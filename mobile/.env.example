# Mobile app env. Copy to `mobile/.env` and fill in. Never commit `.env`.
# Consumed by `mobile/app.config.ts` (loaded via dotenv).

# EAS project id. Run `eas init` in mobile/ to create one under your
# Expo account. The OTA updates URL is derived from this.
EAS_PROJECT_ID=

# Expo account or org that owns the EAS project (your `expo whoami`).
EXPO_OWNER=

# Apple Developer Team ID (10-char string from developer.apple.com).
# Required for code-signing the iOS notification service extension.
APPLE_TEAM_ID=
